# =============================================================================
# gitlab-issue-pipeline — gemeinsame Konfigurationsvorlage
# Kopiere die relevanten Abschnitte in die .env der jeweiligen Bots.
# =============================================================================

# --- Gemeinsam (alle drei Bots) ---
GITLAB_URL=https://gitlab.com
GITLAB_TOKEN=your_gitlab_token        # Scope: api, read_repository

# Webhook-Secret (issue-bot + issue-solver müssen denselben Wert haben)
WEBHOOK_SECRET=your_webhook_secret

# LLM-Provider: groq | openai | mistral
LLM_PROVIDER=groq
GROQ_API_KEY=your_groq_api_key
OPENAI_API_KEY=
MISTRAL_API_KEY=

# --- gitlab-issue-analyzer ---
# Kommagetrennte Projekt-IDs (eine oder mehrere)
GITLAB_PROJECT_ID=your_project_id

# Analyse-Einstellungen
MAX_ISSUES=100
CLOSED_ISSUES_DAYS=90
API_RATE_LIMIT=0.5

# Duplikat-Schwellenwerte (0.0 - 1.0)
DUPLICATE_HIGH_THRESHOLD=0.90
DUPLICATE_MEDIUM_THRESHOLD=0.75

# Unternehmenskontext für LLM-Priorisierung
# Beschreibe was die Software macht, was geschäftskritisch ist und was niedrige Priorität hat.
# Je konkreter, desto besser das Ranking. 3-5 Sätze reichen.
# Beispiel:
# BUSINESS_CONTEXT=Unsere Software ist ein B2B-SaaS für X. Kritisch sind: Rechnungsstellung, Login.
# Weniger kritisch: UI-Verbesserungen, nice-to-have Features.
BUSINESS_CONTEXT=

# --- gitlab-issue-solver ---
# Pfad für geklonte Repos (Docker Volume)
REPOS_BASE_PATH=/repos
